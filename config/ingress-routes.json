{
  "version": 1,
  "ingress": {
    "name": "oficina",
    "namespace": "oficina",
    "ingressClassName": "alb",
    "loadBalancerName": "oficina",
    "scheme": "internal",
    "targetType": "ip",
    "listenerPort": 80
  },
  "aws": {
    "clusterNameParameter": "/oficina/infra/cluster/name",
    "vpcIdParameter": "/oficina/infra/vpc/id",
    "privateSubnet1Parameter": "/oficina/infra/subnets/private/1",
    "privateSubnet2Parameter": "/oficina/infra/subnets/private/2"
  },
  "healthCheck": {
    "path": "/health",
    "protocol": "HTTP",
    "port": "traffic-port",
    "successCodes": "200-399",
    "intervalSeconds": 15,
    "timeoutSeconds": 5,
    "healthyThreshold": 2,
    "unhealthyThreshold": 3
  },
  "healthRouting": {
    "header": "x-oficina-health-target",
    "path": "/health",
    "pathType": "ImplementationSpecific",
    "targets": [
      "cadastro",
      "estoque",
      "ordens"
    ]
  },
  "targetGroupAttributes": {
    "deregistrationDelaySeconds": 30
  },
  "loadBalancerAttributes": {
    "dropInvalidHeaderFields": true
  },
  "backends": [
    {
      "id": "cadastro",
      "serviceName": "oficina-cadastro",
      "servicePort": 8080,
      "paths": [
        "/api/admin/funcionarios",
        "/api/clientes",
        "/api/servicos",
        "/api/veiculos"
      ]
    },
    {
      "id": "estoque",
      "serviceName": "oficina-estoque",
      "servicePort": 80,
      "paths": [
        "/api/estoque",
        "/api/insumos",
        "/api/pecas"
      ]
    },
    {
      "id": "ordens",
      "serviceName": "oficina-ordens-servico",
      "servicePort": 80,
      "paths": [
        "/api/meus-orcamentos",
        "/api/minhas-ordens-servico",
        "/api/orcamentos",
        "/api/ordens-servico",
        "/api/relatorios"
      ]
    }
  ]
}
